{
  "name": "apple-llm-wiki",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "LLM-native source-grounded knowledge base for Apple products",
  "engines": {
    "node": ">=26 <27"
  },
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b --pretty false --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "lint": "biome check .",
    "format": "biome format --write ."
  },
  "dependencies": {},
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^25.9.3",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
