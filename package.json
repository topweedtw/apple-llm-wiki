{
  "name": "apple-llm-wiki",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "LLM-native source-grounded knowledge base for Apple products",
  "engines": {
    "node": ">=26 <27"
  },
  "scripts": {
    "dev": "tsx --env-file-if-exists=.env watch src/api/server.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check .",
    "format": "biome format --write .",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:migrate": "tsx --env-file-if-exists=.env src/db/migrate.ts",
    "cli": "tsx src/cli/index.ts"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "fastify": "^5.1.0",
    "kysely": "^0.27.4",
    "pg": "^8.13.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^22.10.1",
    "@types/pg": "^8.11.10",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}